{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "collectif-feydeau-app",
  "description": "Application web du Collectif Feydeau - Découverte interactive de l'Île Feydeau à Nantes",
  "private": true,
  "version": "1.4.2",
  "type": "module",
  "homepage": "/1Hall1Artiste/",
  "scripts": {
    "dev": "vite",
    "start": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1",
    "build": "vite build && node -e \"const fs=require('fs'); const path=require('path'); console.log('📁 Checking sources...'); fs.mkdirSync('dist/images', {recursive:true}); if(fs.existsSync('public/images/background')){fs.cpSync('public/images/background', 'dist/images/background', {recursive:true}); console.log('✅ Background images copied');}else{console.log('❌ Background source not found');} if(fs.existsSync('public/images/historical')){fs.cpSync('public/images/historical', 'dist/images/historical', {recursive:true}); const count=fs.readdirSync('dist/images/historical').length; console.log('✅ Historical images copied:', count, 'files');}else{console.log('❌ Historical source not found');}\"",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -r https://github.com/CollectifIleFeydeau/1Hall1Artiste.git -b gh-pages",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/update-changelog.js patch",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/update-changelog.js minor",
    "version:major": "npm version major --no-git-tag-version && node scripts/update-changelog.js major",
    "version:show": "node -e \"console.log('Version actuelle:', require('./package.json').version)\"",
    "release": "node scripts/release.js",
    "release:patch": "echo 1 | node scripts/release.js",
    "release:minor": "echo 2 | node scripts/release.js",
    "release:major": "echo 3 | node scripts/release.js"
  },
